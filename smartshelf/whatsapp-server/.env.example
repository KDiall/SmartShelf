# WhatsApp Server Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit real .env files to Git.

# Server port (Render usually sets this automatically, but default is fine)
PORT=10000

# WhatsApp bot phone number in E.164 format
# This is the number that connects to WhatsApp Web and receives/sends messages
CLIENT_PHONE_E164="+232000000000"

# SmartShelf webhook destination
# The WhatsApp server will POST incoming messages to this URL
AGENT_URL="https://your-smartshelf-app.vercel.app/api/webhooks/whatsapp"

# Shared API key for the SmartShelf webhook
# Must match SmartShelf's WHATSAPP_API_KEY
AGENT_API_KEY="your-whatsapp-api-key"

# API key used by SmartShelf to call this server's /send-whatsapp endpoint
# Must match SmartShelf's WHATSAPP_API_KEY
API_KEY="your-whatsapp-api-key"

# Optional branding shown in the connect page and server responses
BRAND_NAME="SmartShelf"
BRAND_TAGLINE="AI Assistant"

# Optional: skip the network check to web.whatsapp.com on startup
SKIP_NETWORK_CHECK=false

# Optional: where WhatsApp session data is stored.
# On Render, mount a persistent disk and point this at it so the bot does NOT
# need to be re-linked (QR scan) after every restart/deploy.
# Example with a Render disk mounted at /data:
# SESSION_DIR=/data/.wwebjs_auth
SESSION_DIR=

# Optional: path to the Chromium binary for Puppeteer.
# The Docker image (ghcr.io/puppeteer/puppeteer) sets this automatically.
# Leave blank for local runs (Puppeteer resolves its own Chromium).
PUPPETEER_EXECUTABLE_PATH=
