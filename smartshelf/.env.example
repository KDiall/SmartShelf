# SmartShelf Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit real .env files to Git.

# Database
# PostgreSQL connection string (e.g., Neon, Supabase, or local Postgres)
DATABASE_URL="postgresql://user:password@host:5432/smartshelf?sslmode=require"

# Auth
# A strong random secret for signing JWT tokens (min 32 characters recommended)
JWT_SECRET="your-jwt-secret-min-32-characters"

# WhatsApp Server
# URL of the separate Node.js whatsapp-web.js server
WHATSAPP_SERVER_URL="https://your-whatsapp-server.onrender.com"
# The WhatsApp phone number used by the bot (E.164 format)
WHATSAPP_CLIENT_PHONE="+232000000000"
# Shared API key between SmartShelf and the WhatsApp server
WHATSAPP_API_KEY="your-whatsapp-api-key"
# (Optional) Override the webhook URL the WhatsApp server should call
WHATSAPP_AGENT_URL="https://your-smartshelf-app.vercel.app/api/webhooks/whatsapp"

# Public app branding
NEXT_PUBLIC_APP_NAME="SmartShelf"
# WhatsApp number used for supplier restock orders
NEXT_PUBLIC_WHATSAPP_SUPPLIER_NUMBER="+23231569311"

# OpenAI
# API key for the AI chatbot (GPT-4o-mini)
OPENAI_API_KEY="sk-your-openai-api-key"

# Geneline / Vector Search
# API key and namespace for retrieving guideline embeddings
GENELINE_X_API_KEY="your-geneline-api-key"
GENELINE_X_NAMESPACE="your-geneline-namespace"

# Public URL
# Used in callbacks, webhooks, and public links
PUBLIC_BASE_URL="https://your-smartshelf-app.vercel.app"

# UploadThing
# Token for PDF and image uploads
UPLOADTHING_TOKEN="your-uploadthing-token"
